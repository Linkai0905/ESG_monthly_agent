# LangSmith Configuration (optional, for monitoring)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=ESG-month-report
LANGSMITH_API_KEY=

# Optional OpenAI-compatible LLM review.
# DeepSeek V4 Pro:
ESG_LLM_API_KEY=
ESG_USE_LLM=false
ESG_LLM_PROVIDER=deepseek
ESG_LLM_MODEL=deepseek-v4-pro
ESG_LLM_BASE_URL=https://api.deepseek.com
ESG_LLM_TIMEOUT_SECONDS=60
ESG_LLM_MAX_TOKENS=1200

# OpenAI-compatible Qwen gateway example. This is chat/review only, not hosted web search.
# ESG_LLM_PROVIDER=qwen-compatible
# ESG_LLM_MODEL=Qwen3.6-35B-A3B.gguf
# ESG_LLM_BASE_URL=https://your-qwen-compatible-endpoint.example/v1
# QWEN_API_KEY=

# OpenAI-compatible GLM gateway example. This is chat/review only, not hosted web search.
# ESG_LLM_PROVIDER=glm-compatible
# ESG_LLM_MODEL=glm-5.2
# ESG_LLM_BASE_URL=https://your-glm-compatible-endpoint.example/v1
# GLM_API_KEY=

# Hosted research mode.
ESG_RESEARCH_MODE=local_vector
ESG_DEFAULT_RESEARCH_PROVIDER=qwen_dashscope_search
ESG_MAX_RESEARCH_ROUNDS=3
ESG_MAX_SEARCH_CALLS_PER_TASK=8
ESG_DEEPSEARCH_CONCURRENCY=3
ESG_REQUIRE_HOSTED_SEARCH_FOR_WEB=true
ESG_ALLOW_FETCH_IN_WEB_MODE=false
OPENAI_WEB_SEARCH_MODEL=gpt-5.5
OPENAI_DEEP_RESEARCH_MODEL=o3-deep-research
OPENAI_DEEP_RESEARCH_ENABLED=false
ANTHROPIC_WEB_SEARCH_MODEL=claude-opus-4-8
ANTHROPIC_WEB_SEARCH_TOOL_TYPE=web_search_20260318
ZHIPU_WEB_SEARCH_API_URL=https://open.bigmodel.cn/api/paas/v4/web_search
ZHIPU_WEB_SEARCH_MODEL=glm-5.2
ZHIPU_WEB_SEARCH_ENGINE=search_pro
ZHIPU_WEB_SEARCH_COUNT=10
ZHIPU_WEB_SEARCH_CONTENT_SIZE=high
ZHIPU_WEB_SEARCH_RECENCY=noLimit
# For a GLM OpenAI-compatible gateway, set:
# ZHIPU_WEB_SEARCH_API_URL=https://your-gateway.example/v1
# ZHIPU_WEB_SEARCH_MODEL=glm-5.2
# ZHIPU_API_KEY=your_gateway_key
TAVILY_SEARCH_API_URL=https://api.tavily.com/search
TAVILY_SEARCH_DEPTH=advanced
TAVILY_SEARCH_MAX_RESULTS=5
# Set true or pass --call-all-available-providers to fan out the first hosted
# DeepSearch round across every configured hosted provider.
ESG_CALL_ALL_AVAILABLE_PROVIDERS=false
QWEN_DASHSCOPE_SEARCH_MODEL=qwen-plus
QWEN_DASHSCOPE_SEARCH_STRATEGY=turbo
# Optional: if your Alibaba Cloud Model Studio key is bound to a workspace-specific endpoint.
# QWEN_DASHSCOPE_WORKSPACE_ID=
# QWEN_DASHSCOPE_REGION=cn-beijing
# QWEN_DASHSCOPE_API_URL=

# Hosted search providers require their own keys.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ZHIPU_API_KEY=
# BIGMODEL_API_KEY=
# TAVILY_API_KEY=
# DASHSCOPE_API_KEY=
# QWEN_DASHSCOPE_API_KEY=

# Legacy-compatible fallbacks also work if you already use them:
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# DASHSCOPE_API_KEY=

# Set to false once real search/fetch tools are configured.
ESG_USE_SEED_EVIDENCE=true
ESG_USE_LOCAL_SOURCES=true
ESG_LOCAL_SOURCE_DIR=storage/raw
ESG_MANUAL_SOURCE_CSV=
ESG_OUTPUT_DIR=runs

# Optional generic search endpoint. It should accept q/top_k query params and
# return either a JSON list or {"results": [...]} with title/url/snippet fields.
ESG_SEARCH_API_URL=
